NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ARIA_API_BASE_URL=
ARIA_BUILD_CONFIG_JSON=

# Neon / Auth (injected by ARIA during build + deploy)
# Production control-plane domains:
# - https://alpha.ariaagi.com
# - https://beta.ariaagi.com
# - https://app.ariaagi.com
# Configure Neon Auth callback/redirect URLs in ARIA to match these hosts.
NEON_DATABASE_URL=

# Stripe runtime (injected by ARIA on deploy)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Test only
E2E_BYPASS_AUTH=
